<!DOCTYPE html>
<html lang="en">
<head>
   
    <title>Bank App</title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            background-color: #f4f4f9;
            padding: 20px;
        }
        .bank-container {
            max-width: 400px;
            margin: 0 auto;
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .input-group {
            margin-bottom: 15px;
        }
        .input-group label {
            display: block;
            margin-bottom: 5px;
        }
        .input-group input {
            width: 100%;
            padding: 8px;
            box-sizing: border-box;
        }
        .button-group {
            margin-bottom: 15px;
        }
        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        .credit {
            background-color: #4caf50;
            color: white;
        }
        .debit {
            background-color: #f44336;
            color: white;
            margin-left: 10px;
        }
        .balance-display {
            font-weight: bold;
            font-size: 1.2em;
        }
  
        .text1 { color: red; text-decoration: overline; }
        .text2 { color: #71ffb0; text-decoration: line-through; }
        .text3 { color: rgb(70, 98, 120); text-decoration: underline; }
        .text4 { color: rgba(0, 0, 0, 0.4); text-decoration: underline overline; }
        .p1 { font-family: "Times New Roman", Times, serif; }
        .p2 { font-family: Arial, Helvetica, sans-serif; }
    </style>
</head>


    <div class="bank-container">
        <h1>Bank App</h1>
        
        <div class="input-group">
            <label for="amount">Enter Transaction Amount:</label>
            <input type="number" id="amount" placeholder="0.00" min="0" step="0.01">
        </div>

        <div class="button-group">
            <button onclick="handleTransaction('credit')" class="btn credit">Credit</button>
            <button onclick="handleTransaction('debit')" class="btn debit">Debit</button>
        </div>

        <p class="balance-display">Your Account Balance is : Rs.<span id="balance">0.00</span></p>
    </div>

    <script src="script.js"></script>
</body>
</html>
